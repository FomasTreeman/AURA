# RAG + LLM config
OLLAMA_MODEL=llama3.2:3b
CHROMA_PATH=./data/chroma_db
INGEST_DIR=./data/documents
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=all-MiniLM-L6-v2

# P2P Network
P2P_PORT=9000
P2P_MDNS_ENABLED=true
P2P_BOOTSTRAP=
NONCE_TTL=300

# Node Orchestration
ORCHESTRATION_ENABLED=true
NODE_IMAGE=aura-backend:latest
NODE_API_PORT_START=8010
NODE_P2P_PORT_START=9010
NODE_MAX_COUNT=10
